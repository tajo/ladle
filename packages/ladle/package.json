{
  "name": "@ladle/react",
  "version": "5.1.1",
  "repository": "git@github.com:tajo/ladle.git",
  "author": "Vojtech Miksu <vojtech@miksu.cz>",
  "license": "MIT",
  "type": "module",
  "types": "./lib/app/exports.ts",
  "exports": {
    ".": "./lib/app/exports.ts",
    "./serve": "./api/serve.js",
    "./preview": "./api/preview.js",
    "./build": "./api/build.js",
    "./meta": "./api/meta.js",
    "./msw-node": "./api/msw-node.js"
  },
  "packageManager": "pnpm@11.9.0",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "lib",
    "api",
    "typings-for-build"
  ],
  "bin": {
    "ladle": "./lib/cli/cli.js"
  },
  "scripts": {
    "cli": "node ./lib/cli/cli.js",
    "clean": "rimraf dist && rimraf .ladle && rimraf build && rimraf *.tsbuildinfo",
    "serve": "node ./lib/cli/cli.js serve",
    "test": "cross-env IMPORT_ROOT=\"./\" vitest run",
    "test:watch": "cross-env IMPORT_ROOT=\"./\" vitest",
    "types": "tsc --project tsconfig.typesoutput.json && cp ./typings-for-build/app/exports.d.ts ./typings-for-build/app/exports.d.cts && cp -r -n ./lib/app ./typings-for-build/ || true && ./scripts/update-index-path.js"
  },
  "dependencies": {
    "@babel/code-frame": "^8.0.0",
    "@babel/core": "^8.0.1",
    "@babel/generator": "^8.0.0",
    "@babel/parser": "^8.0.0",
    "@babel/template": "^8.0.0",
    "@babel/traverse": "^8.0.0",
    "@babel/types": "^8.0.0",
    "@ladle/react-context": "^1.0.1",
    "@mdx-js/mdx": "^3.1.1",
    "@mdx-js/react": "^3.1.1",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "axe-core": "^4.12.1",
    "boxen": "^8.0.1",
    "chokidar": "^5.0.0",
    "classnames": "^2.5.1",
    "commander": "^15.0.0",
    "cross-spawn": "^7.0.6",
    "debug": "^4.4.3",
    "get-port": "^7.2.0",
    "globby": "^16.2.0",
    "history": "^5.3.0",
    "koa": "^3.2.1",
    "lodash.merge": "^4.6.2",
    "msw": "^2.14.6",
    "open": "^11.0.0",
    "prism-react-renderer": "^2.4.1",
    "prop-types": "^15.8.1",
    "query-string": "^9.4.0",
    "react-hotkeys-hook": "^5.3.3",
    "react-inspector": "^9.0.0",
    "rehype-class-names": "^2.0.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "source-map": "^0.7.6",
    "vfile": "^6.0.3",
    "vite": "^8.1.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@babel/cli": "^8.0.1",
    "@types/babel__code-frame": "^7.27.0",
    "@types/babel__core": "^7.20.5",
    "@types/babel__generator": "^7.27.0",
    "@types/babel__template": "^7.4.4",
    "@types/babel__traverse": "^7.28.0",
    "@types/cross-spawn": "^6.0.6",
    "@types/debug": "^4.1.13",
    "@types/express": "^5.0.6",
    "@types/koa": "^3.0.3",
    "@types/lodash.merge": "^4.6.9",
    "@types/node": "^26.0.1",
    "@types/ws": "^8.18.1",
    "cross-env": "^10.1.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
